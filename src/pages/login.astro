---
import Layout from "../layouts/Layout.astro";
import GoogleAuth from "../components/GoogleAuth.jsx";
---

<Layout title="Iniciar Sesión | Nordika Wear">
  <section class="min-h-screen flex items-center justify-center bg-gray-950 p-4">
    <div
      class="max-w-4xl w-full bg-gray-900 rounded-2xl shadow-2xl overflow-hidden flex flex-col md:flex-row border border-gray-800"
    >
      <div class="relative w-full h-48 md:h-auto md:w-1/2 bg-indigo-600">
        <img
          src="https://images.unsplash.com/photo-1523381210434-271e8be1f52b?auto=format&fit=crop&q=80"
          alt="Ropa personalizada"
          class="absolute inset-0 w-full h-full object-cover mix-blend-overlay opacity-50"
        />
        <div class="relative z-10 p-6 md:p-10 flex flex-col justify-center h-full text-white">
          <h2 class="text-3xl md:text-4xl font-bold mb-2 md:mb-4">Nordika Wear</h2>
          <p class="text-indigo-100 italic text-sm md:text-base">"Tu estilo, tus reglas."</p>
        </div>
      </div>

      <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col justify-center">
        <h3 class="text-2xl font-bold text-white mb-2">Bienvenido de nuevo</h3>
        <p class="text-gray-400 mb-8">Ingresa tus datos para acceder</p>

        <form class="space-y-6" id="loginForm" action="javascript:void(0)" onsubmit="return false">
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Usuario (o Email)</label>
            <input
              type="text"
              name="username"
              required
              class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 text-white focus:ring-indigo-500 outline-none transition"
              placeholder="Tu usuario"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Contraseña</label>
            <div class="relative">
              <input
                type="password"
                id="password"
                name="password"
                required
                class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 pr-10 text-white focus:ring-2 focus:ring-indigo-500 outline-none transition"
                placeholder="••••••••"
              />
              <button
                type="button"
                id="togglePassword"
                class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-white transition"
              >
                <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
                <svg id="eyeOffIcon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>
              </button>
            </div>
          </div>

          <button
            type="submit"
            class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 rounded-lg transition-all transform hover:scale-[1.02]"
            >Entrar
          </button>
        </form>

        <div class="mt-6 flex items-center justify-center space-x-2">
          <span class="h-px w-full bg-gray-800"></span>
          <span class="text-gray-500 font-medium text-sm">o</span>
          <span class="h-px w-full bg-gray-800"></span>
        </div>

        <div class="mt-6">
          <GoogleAuth client:load />
        </div>

        <p class="mt-8 text-center text-sm text-gray-500">
          ¿No tienes una cuenta? <a href="/registro" class="text-indigo-400 hover:underline">Registrate aquí</a>
        </p>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { authService } from "../services/authService";
  import { sileo } from "sileo";

  // Opciones de modo claro para login/registro
  const lightToastOpts = {
    fill: "#ffffff",
    styles: {
      title: "text-gray-800 font-bold",
      description: "text-gray-600",
    },
  };

  function initPasswordToggle() {
    const toggleBtn = document.getElementById("togglePassword");
    const passInput = document.getElementById("password") as HTMLInputElement;
    const eyeIcon = document.getElementById("eyeIcon");
    const eyeOffIcon = document.getElementById("eyeOffIcon");

    if (toggleBtn && passInput) {
      toggleBtn.addEventListener("click", () => {
        const isPassword = passInput.getAttribute("type") === "password";
        passInput.setAttribute("type", isPassword ? "text" : "password");
        if (eyeIcon && eyeOffIcon) {
          eyeIcon.classList.toggle("hidden", isPassword);
          eyeOffIcon.classList.toggle("hidden", !isPassword);
        }
      });
    }
  }

  function initLoginForm() {
    const form = document.getElementById("loginForm") as HTMLFormElement | null;
    if (!form) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      e.stopPropagation();

      const submitBtn = form.querySelector("button[type='submit']") as HTMLButtonElement | null;
      if (submitBtn) submitBtn.disabled = true;

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      try {
        sileo.info({ title: "Iniciando sesión...", ...lightToastOpts });

        const result = await authService.login(data);

        
        const userName =
          result?.user_name ||
          (localStorage.getItem("user_name") ?? "");
        if (userName) {
          sessionStorage.setItem("show_welcome", userName);
        }

        sileo.success({ title: "¡Sesión iniciada!", description: "Redirigiendo...", ...lightToastOpts });
        setTimeout(() => { window.location.href = "/"; }, 1200);
      } catch (error: any) {
        if (submitBtn) submitBtn.disabled = false;
        console.error(error);

        const serverDetail = error.response?.data?.detail;
        let mensajeEspañol = "Ocurrió un error inesperado";

        if (serverDetail === "No active account found with the given credentials") {
          mensajeEspañol = "Correo o contraseña incorrectos. Inténtalo de nuevo.";
        } else if (error.response?.status === 401) {
          mensajeEspañol = "No tienes permiso para acceder o tu cuenta no está activa.";
        } else if (error.code === "ERR_NETWORK") {
          mensajeEspañol = "No se pudo conectar con el servidor. Revisa tu internet.";
        }

        sileo.error({ title: "Error al iniciar sesión", description: mensajeEspañol, ...lightToastOpts });
      }
    });
  }

  // Garantizar que el DOM esté listo antes de adjuntar el listener
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      initLoginForm();
      initPasswordToggle();
    });
  } else {
    initLoginForm();
    initPasswordToggle();
  }
</script>
