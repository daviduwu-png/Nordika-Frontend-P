---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Crear Cuenta | Nordika Wear">
  <section class="relative min-h-screen flex items-stretch">
    <div class="absolute inset-0 z-0">
      <img
        src="https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&q=80"
        class="w-full h-full object-cover opacity-40"
        alt="Fondo textura"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-gray-950/90 via-gray-950/70 to-gray-950"></div>
    </div>

    <div
      class="relative z-10 w-full md:w-1/2 flex items-center justify-center p-6 bg-transparent md:bg-gray-900 transition-colors duration-300"
    >
      <div
        class="w-full max-w-md bg-gray-900/60 md:bg-transparent backdrop-blur-md md:backdrop-blur-none border border-white/10 md:border-none rounded-3xl p-8 shadow-2xl md:shadow-none"
      >
        <div class="mb-8 text-center md:text-left">
          <h2 class="text-3xl font-extrabold text-white inline-block pb-2 border-b-2 border-indigo-500">
            Únete a Nordika
          </h2>
          <p class="text-gray-300 mt-2 text-sm">Crea tu cuenta y empieza a personalizar.</p>
        </div>

        <form class="space-y-5" id="registerForm" action="javascript:void(0)" onsubmit="return false">
          <div class="flex gap-4">
            <div class="w-1/2">
              <label class="block text-xs uppercase tracking-widest text-indigo-400 font-bold mb-2"> Nombre </label>
              <input
                type="text"
                name="first_name"
                required
                pattern="[a-zA-ZáéíóúÁÉÍÓÚñÑ ]+"
                title="Solo se permiten letras y espacios"
                class="w-full bg-gray-800/80 border border-gray-700 rounded-xl px-4 py-3 text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all placeholder-gray-500"
                placeholder="Juan"
              />
            </div>

            <div class="w-1/2">
              <label class="block text-xs uppercase tracking-widest text-indigo-400 font-bold mb-2"> Apellidos </label>
              <input
                type="text"
                name="last_name"
                required
                pattern="[a-zA-ZáéíóúÁÉÍÓÚñÑ ]+"
                title="Solo se permiten letras y espacios"
                class="w-full bg-gray-800/80 border border-gray-700 rounded-xl px-4 py-3 text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all placeholder-gray-500"
                placeholder="Pérez"
              />
            </div>
          </div>

          <div>
            <label class="block text-xs uppercase tracking-widest text-indigo-400 font-bold mb-2">
              Nombre de Usuario
            </label>
            <input
              type="text"
              id="username"
              name="username"
              required
              minlength="4"
              pattern="[a-zA-Z0-9_]+"
              title="Mínimo 4 caracteres, solo letras, números y guiones bajos"
              class="w-full bg-gray-800/80 border border-gray-700 rounded-xl px-4 py-3 text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all placeholder-gray-500"
              placeholder="JuanPerez99"
            />
          </div>

          <div>
            <label class="block text-xs uppercase tracking-widest text-indigo-400 font-bold mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-gray-800/80 border border-gray-700 rounded-xl px-4 py-3 text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all placeholder-gray-500"
              placeholder="hola@ejemplo.com"
            />
          </div>

          <div>
            <label class="block text-xs uppercase tracking-widest text-indigo-400 font-bold mb-2">Contraseña</label>
            <div class="relative">
              <input
                type="password"
                id="password"
                name="password"
                required
                minlength="8"
                title="La contraseña debe tener al menos 8 caracteres"
                class="w-full bg-gray-800/80 border border-gray-700 rounded-xl px-4 py-3 pr-10 text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all placeholder-gray-500"
                placeholder="••••••••"
              />
              <button
                type="button"
                id="togglePassword"
                class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-white transition"
              >
                <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
                <svg id="eyeOffIcon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>
              </button>
            </div>
          </div>

          <button
            type="submit"
            class="w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-indigo-500 hover:to-blue-500 text-white font-semibold py-3 rounded-xl shadow-lg shadow-indigo-500/30 transition-all transform active:scale-95 mt-4"
          >
            Crear mi cuenta
          </button>
        </form>

        <p class="mt-8 text-center text-sm text-gray-400">
          ¿Ya eres miembro? <a href="/login" class="text-indigo-400 hover:text-indigo-300 font-bold transition">
            Inicia sesión
          </a>
        </p>
      </div>
    </div>

    <div class="hidden md:block md:w-1/2 relative z-10">
      <img
        src="https://images.unsplash.com/photo-1483985988355-763728e1935b?auto=format&fit=crop&q=80"
        alt="Moda urbana"
        class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-overlay"
      />
      <div class="absolute inset-0 bg-gradient-to-l from-transparent to-gray-900"></div>

      <div class="absolute bottom-0 right-0 p-12 text-right z-20">
        <h3 class="text-5xl font-bold text-white mb-2 tracking-tight">Estilo Propio</h3>
        <p class="text-indigo-200 text-xl font-light">Diseña sin límites.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { authService } from "../services/authService";
  import { sileo } from "sileo";

  // Opciones de modo claro para login/registro
  const lightToastOpts = {
    fill: "#ffffff",
    styles: {
      title: "text-gray-800 font-bold",
      description: "text-gray-600",
    },
  };

  function initPasswordToggle() {
    const toggleBtn = document.getElementById("togglePassword");
    const passInput = document.getElementById("password") as HTMLInputElement;
    const eyeIcon = document.getElementById("eyeIcon");
    const eyeOffIcon = document.getElementById("eyeOffIcon");

    if (toggleBtn && passInput) {
      toggleBtn.addEventListener("click", () => {
        const isPassword = passInput.getAttribute("type") === "password";
        passInput.setAttribute("type", isPassword ? "text" : "password");
        if (eyeIcon && eyeOffIcon) {
          eyeIcon.classList.toggle("hidden", isPassword);
          eyeOffIcon.classList.toggle("hidden", !isPassword);
        }
      });
    }
  }

  function initRegisterForm() {
    const form = document.getElementById("registerForm") as HTMLFormElement | null;
    if (!form) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      e.stopPropagation();

      const submitBtn = form.querySelector("button[type='submit']") as HTMLButtonElement | null;
      if (submitBtn) submitBtn.disabled = true;

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      try {
        sileo.info({ title: "Procesando registro...", ...lightToastOpts });
        await authService.register(data);
        sileo.success({ title: "¡Cuenta creada!", description: "Redirigiendo al login...", ...lightToastOpts });

        setTimeout(() => {
          window.location.href = "/login";
        }, 2000);
      } catch (error: any) {
        if (submitBtn) submitBtn.disabled = false;
        console.error(error);

        let mensajeEspañol = "Ocurrió un error inesperado";
        const errorData = error.response?.data;

        if (error.code === "ERR_NETWORK") {
          mensajeEspañol = "No se pudo conectar con el servidor. Revisa tu internet.";
        } else if (error.response?.status === 400 && errorData) {
          if (errorData.username) {
            mensajeEspañol = "Este nombre de usuario ya está en uso o no es válido.";
          } else if (errorData.email) {
            mensajeEspañol = "El correo electrónico ya está registrado o es inválido.";
          } else if (errorData.password) {
            mensajeEspañol = "La contraseña no cumple con los requisitos mínimos.";
          } else {
            mensajeEspañol = "Datos incorrectos. Revisa la información ingresada.";
          }
        }

        sileo.error({ title: "Error en el registro", description: mensajeEspañol, ...lightToastOpts });
      }
    });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      initRegisterForm();
      initPasswordToggle();
    });
  } else {
    initRegisterForm();
    initPasswordToggle();
  }
</script>
