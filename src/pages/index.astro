---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";

import { productService } from "../services/productService";
const productos = await productService.getAllProducts();

const productosDestacados = productos.slice(0, 4);
---

<Layout title="Bienvenido a Nordika Wear">
  <section class="relative bg-gray-50 py-20 text-center overflow-hidden">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-indigo-200 rounded-full blur-3xl opacity-20 -z-10"
    >
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <span class="text-indigo-600 font-bold tracking-widest uppercase text-xs mb-2 block">Nueva Colección 2026</span>
      <h2 class="text-5xl md:text-7xl font-extrabold mb-6 text-gray-900 tracking-tight">
        Ropa que habla <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">por ti.</span>
      </h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        Diseños exclusivos, materiales premium y personalización total. Tu estilo no tiene límites.
      </p>

      <div class="flex gap-4 justify-center">
        <a
          href="/catalogo"
          class="bg-gray-900 text-white px-8 py-4 rounded-full font-bold hover:bg-gray-800 transition shadow-lg hover:shadow-xl transform hover:-translate-y-1"
        >
          Ver Colección
        </a>
        <a
          href="#destacados"
          class="bg-white text-gray-900 border border-gray-200 px-8 py-4 rounded-full font-bold hover:bg-gray-50 transition"
        >
          Más vendidos
        </a>
      </div>
    </div>
  </section>

  <section id="destacados" class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h3 class="text-3xl font-bold text-gray-900">Tendencias de la semana</h3>
          <p class="text-gray-500 mt-2">Las piezas favoritas de nuestra comunidad.</p>
        </div>
        <a
          href="/catalogo"
          class="hidden md:flex items-center text-indigo-600 font-bold hover:text-indigo-800 transition group"
        >
          Ver todo el catálogo
          <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
        {
          productosDestacados.map((producto: any) => (
            <ProductCard
              name={producto.name}
              price={producto.price}
              image={producto.image}
              category={producto.category}
              slug={producto.slug}
            />
          ))
        }
      </div>

      <div class="mt-12 text-center md:hidden">
        <a
          href="/catalogo"
          class="inline-block border border-gray-300 px-8 py-3 rounded-full text-gray-700 font-semibold hover:bg-gray-50 transition"
        >
          Ver todo el catálogo
        </a>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50 border-t border-gray-200">
    <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <div class="p-6">
        <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl">
          🚀
        </div>
        <h4 class="text-xl font-bold mb-2">Envío Rápido</h4>
        <p class="text-gray-600">Recibe tus diseños personalizados en tiempo récord.</p>
      </div>
      <div class="p-6">
        <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl">
          💎
        </div>
        <h4 class="text-xl font-bold mb-2">Calidad Premium</h4>
        <p class="text-gray-600">Telas seleccionadas para durar y sentirse increíbles.</p>
      </div>
      <div class="p-6">
        <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4 text-3xl">🛡️</div>
        <h4 class="text-xl font-bold mb-2">Pago Seguro</h4>
        <p class="text-gray-600">Tus transacciones protegidas con la mejor tecnología.</p>
      </div>
    </div>
  </section>
</Layout>
