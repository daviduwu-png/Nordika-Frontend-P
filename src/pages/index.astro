---
import Layout from "../layouts/Layout.astro";
import { Truck, Gem, ShieldCheck } from "lucide-react";
import FeaturedProducts from "../components/FeaturedProducts.jsx";
---

<Layout title="Bienvenido a Nordika Wear">
  <section class="relative bg-gray-50 py-20 text-center overflow-hidden">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-indigo-200 rounded-full blur-3xl opacity-20 -z-10"
    >
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <span class="text-indigo-600 font-bold tracking-widest uppercase text-xs mb-2 block">Nueva Colección 2026</span>
      <h2 class="text-5xl md:text-7xl font-extrabold mb-6 text-gray-900 tracking-tight">
        Ropa que habla <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-600">por ti.</span>
      </h2>
      <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
        Diseños exclusivos, materiales premium y personalización total. Tu estilo no tiene límites.
      </p>

      <div class="flex gap-4 justify-center">
        <a
          href="/catalogo"
          class="bg-gray-900 text-white px-8 py-4 rounded-full font-bold hover:bg-gray-800 transition shadow-lg hover:shadow-xl transform hover:-translate-y-1"
        >
          Ver Colección
        </a>
        <a
          href="#destacados"
          class="bg-white text-gray-900 border border-gray-200 px-8 py-4 rounded-full font-bold hover:bg-gray-50 transition"
        >
          Más vendidos
        </a>
      </div>
    </div>
  </section>

  <section id="destacados" class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-end mb-12">
        <div>
          <h3 class="text-3xl font-bold text-gray-900">Tendencias de la semana</h3>
          <p class="text-gray-500 mt-2">Las piezas favoritas de nuestra comunidad.</p>
        </div>
        <a
          href="/catalogo"
          class="hidden md:flex items-center text-indigo-600 font-bold hover:text-indigo-800 transition group"
        >
          Ver todo el catálogo
          <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

      <FeaturedProducts client:load />

      <div class="mt-12 text-center md:hidden">
        <a
          href="/catalogo"
          class="inline-block border border-gray-300 px-8 py-3 rounded-full text-gray-700 font-semibold hover:bg-gray-50 transition"
        >
          Ver todo el catálogo
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white border-t border-gray-100">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16">
        <h3 class="text-3xl font-bold text-gray-900 tracking-tight">Por qué elegir Nordika</h3>
        <p class="text-gray-500 mt-4 max-w-2xl mx-auto">Nos dedicamos a brindarte la mejor experiencia de compra con beneficios diseñados especialmente para ti.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center max-w-6xl mx-auto">
        <div class="p-6 group hover:-translate-y-2 transition-transform duration-300">
          <div class="w-16 h-16 bg-gray-50 text-indigo-600 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-gray-100 shadow-sm group-hover:shadow-md transition-all">
            <Truck size={28} strokeWidth={1.5} />
          </div>
          <h4 class="text-lg font-bold mb-3 text-gray-900 tracking-tight">Envío Rápido</h4>
          <p class="text-gray-500 leading-relaxed text-sm">Recibe tus diseños personalizados en tiempo récord, directo a la puerta de tu casa.</p>
        </div>

        <div class="p-6 group hover:-translate-y-2 transition-transform duration-300">
          <div class="w-16 h-16 bg-gray-50 text-indigo-600 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-gray-100 shadow-sm group-hover:shadow-md transition-all">
            <Gem size={28} strokeWidth={1.5} />
          </div>
          <h4 class="text-lg font-bold mb-3 text-gray-900 tracking-tight">Calidad Premium</h4>
          <p class="text-gray-500 leading-relaxed text-sm">Telas seleccionadas cuidadosamente para durar, mantener su forma y sentirse increíbles.</p>
        </div>

        <div class="p-6 group hover:-translate-y-2 transition-transform duration-300">
          <div class="w-16 h-16 bg-gray-50 text-indigo-600 rounded-2xl flex items-center justify-center mx-auto mb-6 border border-gray-100 shadow-sm group-hover:shadow-md transition-all">
            <ShieldCheck size={28} strokeWidth={1.5} />
          </div>
          <h4 class="text-lg font-bold mb-3 text-gray-900 tracking-tight">Cifrado Seguro</h4>
          <p class="text-gray-500 leading-relaxed text-sm">Tus datos y transacciones están protegidas con tecnología de seguridad de última generación.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { sileo } from "sileo";

  const welcomeName = sessionStorage.getItem("show_welcome");
  if (welcomeName) {
    sessionStorage.removeItem("show_welcome");
    setTimeout(() => {
      sileo.info({
        title: `¡Bienvenido, ${welcomeName}!`,
        description: "Es un placer verte por aquí",
        duration: 5000,
        styles: {
          title: "text-blue-400 font-bold",
          description: "text-gray-300 text-center block w-full",
        }
      });
    }, 400);
  }
</script>

