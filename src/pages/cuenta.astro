---
import Layout from "../layouts/Layout.astro";

import { Package, MapPin, CreditCard, LogOut, Truck, CheckCircle } from "lucide-react";

const usuario = { nombre: "Juan Pérez", email: "juan@ejemplo.com" }; // Simulado
---

<Layout title="Mi Cuenta | Nordika Wear">
  <div class="bg-gray-50 min-h-screen py-10">
    <div class="container mx-auto px-4">
      <h1 class="text-3xl font-bold text-gray-900 mb-8">Mi Cuenta</h1>

      <div class="flex flex-col md:flex-row gap-8">
        <aside class="w-full md:w-64 flex-shrink-0">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-6 border-b border-gray-100 bg-gray-50">
              <p class="font-bold text-gray-900">{usuario.nombre}</p>
              <p class="text-xs text-gray-500">{usuario.email}</p>
            </div>
            <nav class="flex flex-col p-2">
              <a
                href="#"
                class="flex items-center gap-3 px-4 py-3 text-indigo-600 bg-indigo-50 rounded-lg font-medium transition-colors"
              >
                <Package size={20} /> Mis Pedidos
              </a>
              <a
                href="#"
                class="flex items-center gap-3 px-4 py-3 text-gray-600 hover:bg-gray-50 rounded-lg transition-colors"
              >
                <MapPin size={20} /> Direcciones
              </a>
              <a
                href="#"
                class="flex items-center gap-3 px-4 py-3 text-gray-600 hover:bg-gray-50 rounded-lg transition-colors"
              >
                <CreditCard size={20} /> Métodos de Pago
              </a>
              <button
                class="flex items-center gap-3 px-4 py-3 text-red-500 hover:bg-red-50 rounded-lg transition-colors text-left mt-4 border-t border-gray-100 w-full"
              >
                <LogOut size={20} /> Cerrar Sesión
              </button>
            </nav>
          </div>
        </aside>

        <main class="flex-1">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-xl font-bold mb-6">Historial de Pedidos</h2>

            <div class="space-y-4">
              <div
                class="border border-gray-200 rounded-lg p-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 hover:border-indigo-200 transition-colors"
              >
                <div>
                  <div class="flex items-center gap-3 mb-1">
                    <span class="font-bold text-gray-900">#ORD-001</span>
                    <span
                      class="bg-green-100 text-green-700 text-xs px-2 py-0.5 rounded-full font-bold flex items-center gap-1"
                    >
                      <CheckCircle size={12} /> Entregado
                    </span>
                  </div>
                  <p class="text-sm text-gray-500">24 Oct 2024 • 3 artículos</p>
                </div>
                <div class="text-right">
                  <p class="font-bold text-gray-900">$1,250.00</p>
                  <a
                    href="#"
                    class="text-indigo-600 text-sm font-medium hover:underline flex items-center gap-1 justify-end"
                  >
                    Ver detalles
                  </a>
                </div>
              </div>

              <div
                class="border border-gray-200 rounded-lg p-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 hover:border-indigo-200 transition-colors"
              >
                <div>
                  <div class="flex items-center gap-3 mb-1">
                    <span class="font-bold text-gray-900">#ORD-002</span>
                    <span
                      class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full font-bold flex items-center gap-1"
                    >
                      <Truck size={12} /> En camino
                    </span>
                  </div>
                  <p class="text-sm text-gray-500">26 Oct 2024 • 1 artículo</p>
                </div>
                <div class="text-right">
                  <p class="font-bold text-gray-900">$350.00</p>
                  <a
                    href="#"
                    class="text-indigo-600 text-sm font-medium hover:underline flex items-center gap-1 justify-end"
                  >
                    Rastrear envío
                  </a>
                </div>
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>
</Layout>
