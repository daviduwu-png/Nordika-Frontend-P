---
import Layout from "../layouts/Layout.astro";
import CheckoutForm from "../components/Checkout/CheckoutForm.jsx";
---

<Layout title="Finalizar Compra | Nordika Wear">
  <div class="bg-white min-h-screen py-10 pb-20">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="mb-10 text-center md:text-left border-b border-gray-100 pb-6">
        <h1 class="text-3xl font-extrabold text-gray-900">Finalizar Compra</h1>
        <p class="text-gray-500 mt-2">Estás a un paso de estrenar tu estilo.</p>
      </div>

      <CheckoutForm client:only="react" />
    </div>
  </div>
</Layout>
